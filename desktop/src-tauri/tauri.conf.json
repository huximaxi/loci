{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "loci wizard",
  "version": "0.2.0",
  "identifier": "garden.loci.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "dmg": {
        "appName": "loci wizard"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "loci wizard",
        "width": 680,
        "height": 520,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": {
      "all": true,
      "open": true
    },
    "opener": {
      "all": true,
      "open": true
    }
  }
}
