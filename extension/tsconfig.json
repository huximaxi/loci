{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@loci/core/*": ["../packages/core/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../packages/core/src/**/*"
  ]
}
